datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("EDITOR") // SQLite doesn't support enums natively, use String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blogs     Blog[]
}

model Project {
  id           String      @id @default(uuid())
  title        String
  description  String
  longDesc     String
  category     String      // Residential, Commercial, Turnkey, Renovation
  coverImage   String
  images       String      // SQLite doesn't support String[] arrays natively, store as JSON/string
  location     String
  client       String
  area         String      // e.g. "2,500 sq ft"
  materials    String      // Store as comma-separated string or JSON string
  duration     String      // e.g. "6 Months"
  testimonial  String?
  clientName   String?
  clientRole   String?
  isFeatured   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Service {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String
  longDesc     String
  icon         String   // Lucide icon name
  coverImage   String
  gallery      String   // Store as JSON/comma-separated string
  processSteps String   // Store as JSON/comma-separated string
  features     String   // Store as JSON/comma-separated string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String
  coverImage  String
  category    String
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(uuid())
  name       String
  role       String
  company    String?
  rating     Float    @default(5.0)
  review     String
  avatar     String?
  videoUrl   String?  // Optional video testimonial url
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model GalleryItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  category    String   // Residential, Commercial, Exterior, Details
  width       Int      @default(800)
  height      Int      @default(600)
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String   // General, Residential, Billing, Process
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  bio       String
  image     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
